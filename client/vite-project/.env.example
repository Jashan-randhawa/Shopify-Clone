# Leave empty for development (Vite proxy handles /api -> localhost:3001)
# In production, set this to your backend URL:
# VITE_API_URL=https://your-backend.onrender.com
VITE_API_URL=

# Socket URL for chat (defaults to localhost:3001 if not set)
# VITE_SOCKET_URL=https://your-backend.onrender.com
VITE_SOCKET_URL=
