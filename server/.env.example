# MongoDB connection string
MONGO_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/shopify-clone

# JWT secret - use a long random string
JWT_SECRET=your_long_random_secret_here

# Environment
NODE_ENV=development

# Server port (backend runs here)
PORT=3001

# Frontend URL for CORS (in production, set to your deployed frontend URL)
# In development this is not needed - localhost:5173 is allowed by default
CLIENT_URL=https://your-frontend.onrender.com
